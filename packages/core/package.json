{
  "name": "@tsuki/core",
  "version": "0.1.0",
  "description": "Application runtime, DI container, and metadata utils for Tsuki framework",
  "repository": {
    "type": "git",
    "url": "https://github.com/innei/tsuki",
    "directory": "packages/core"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tsuki/common": "workspace:*",
    "hono": "4.12.12",
    "picocolors": "1.1.1",
    "reflect-metadata": "0.2.2",
    "tsyringe": "4.10.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "unplugin-swc": "1.5.9",
    "vitest": "4.0.18",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  }
}
