{
  "name": "@tsuki-hono/openapi",
  "version": "0.0.2",
  "description": "OpenAPI 3.1 document generation for Tsuki framework",
  "repository": {
    "type": "git",
    "url": "https://github.com/innei/tsuki",
    "directory": "packages/openapi"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@tsuki-hono/common": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  }
}
